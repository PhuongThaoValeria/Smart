# ===========================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# ===========================================

# Database Configuration (Development)
DATABASE_URL=postgresql://user:password@localhost:5432/english_testprep
DB_HOST=localhost
DB_PORT=5432
DB_NAME=english_testprep
DB_USER=user
DB_PASSWORD=password

# Anthropic API (Claude) - REQUIRED
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (Optional - for embedding generation)
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
APP_NAME=Smart English Test-Prep Agent
APP_VERSION=1.0.0
ENVIRONMENT=development

# FastAPI Configuration (Development)
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Frontend Configuration (Development)
FRONTEND_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Test Configuration
DAILY_TEST_DURATION_MINUTES=15
DAILY_TEST_QUESTION_COUNT=15
MEGA_TEST_DURATION_MINUTES=60
MEGA_TEST_QUESTION_COUNT=50

# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES (VERCEL)
# ===========================================
# Copy these to Vercel Dashboard → Settings → Environment Variables

# Database (Production) - Use Supabase, Neon, or AWS RDS
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API Key (REQUIRED) - Get from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key (Optional)
# OPENAI_API_KEY=sk-xxxxx

# Environment
# ENVIRONMENT=production

# JWT Secret (Generate a strong random string)
# JWT_SECRET_KEY=generate-strong-random-string-here

# Frontend URL (Auto-set by Vercel, but can override)
# FRONTEND_URL=https://your-domain.vercel.app

# ===========================================
# NEXT.JS PUBLIC VARIABLES (Frontend)
# ===========================================
# These are prefixed with NEXT_PUBLIC_ and exposed to browser

# Development: Uses localhost:8000
# Production: Uses /api (relative path to Vercel serverless functions)
# NEXT_PUBLIC_API_URL=http://localhost:8000